generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sector {
  A
  B
  C
  D
}

enum PackUnit {
  UN
  CX
  PAL
}

enum MovementType {
  ENTRADA
  SAIDA
}

enum LoadStatus {
  ARMAZENADA
  SEPARADA
  RETIRADA
}

model Client {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inbounds  Inbound[]
  outbounds Outbound[]
}

model Product {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inboundLines  InboundLine[]
  outboundLines OutboundLine[]
}

model Inbound {
  id              String   @id @default(uuid())
  clientId        String
  destinationCity String
  supplierOrBrand String?
  sector          Sector
  notes           String?
  status          LoadStatus @default(ARMAZENADA)
  createdAt       DateTime @default(now())

  client   Client           @relation(fields: [clientId], references: [id])
  invoices InboundInvoice[]
  lines    InboundLine[]

  @@index([clientId])
}

model InboundInvoice {
  id               String @id @default(uuid())
  inboundId        String
  clientId         String?
  number           String
  numberNormalized String?

  inbound Inbound @relation(fields: [inboundId], references: [id], onDelete: Cascade)

  @@index([number])
  @@index([clientId, numberNormalized])
  @@unique([clientId, numberNormalized])
}

model InboundLine {
  id        String   @id @default(uuid())
  inboundId String
  productId String
  quantity  Decimal  @db.Decimal(18, 4)
  unit      PackUnit

  inbound Inbound @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([inboundId])
}

model Outbound {
  id                String   @id @default(uuid())
  clientId          String
  exitInvoiceNumber String
  withdrawalDate    DateTime
  pickedUpBy        String
  destination       String
  notes             String?
  createdAt         DateTime @default(now())

  client Client         @relation(fields: [clientId], references: [id])
  lines  OutboundLine[]

  @@index([clientId])
  @@index([exitInvoiceNumber])
}

model OutboundLine {
  id         String   @id @default(uuid())
  outboundId String
  productId  String
  quantity   Decimal  @db.Decimal(18, 4)
  unit       PackUnit
  sector     Sector

  outbound Outbound @relation(fields: [outboundId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([outboundId])
}

model StockMovement {
  id            String       @id @default(uuid())
  occurredAt    DateTime
  type          MovementType
  clientId      String
  productId     String
  quantity      Decimal      @db.Decimal(18, 4)
  unit          PackUnit
  sector        Sector
  referenceType String
  referenceId   String

  @@index([occurredAt])
  @@index([clientId, productId, occurredAt])
  @@index([clientId, productId, sector, unit])
  @@index([type])
}

model StockBalance {
  id        String   @id @default(uuid())
  clientId  String
  productId String
  sector    Sector
  unit      PackUnit
  quantity  Decimal  @db.Decimal(18, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, productId, sector, unit])
  @@index([clientId, productId])
  @@index([sector, unit])
}
